# JWT
JWT_SECRET=ba271ac734ba5def6a329aeff649db197f156d345ea4f6289c3a9898d181bfa3 # openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Embeddings (OpenAI-compatible)
EMBEDDING_BASE_URL=http://192.168.1.150:8082/v1
EMBEDDING_API_KEY=no
EMBEDDING_MODEL=Qwen3-Embedding-0.6B-Q8_0.gguf
EMBEDDING_DIMENSIONS=1024

# Document ingestion
CHUNK_SIZE=1024
CHUNK_OVERLAP=50
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_data
MAX_UPLOAD_SIZE_MB=50

# Hybrid search (BM25 + vector fusion)
HYBRID_SEARCH_ENABLED=true
RRF_K=60
RETRIEVAL_CANDIDATE_K=20
FINAL_TOP_K=5

# Relevance filtering (0.0 = disabled; only useful for vector-only mode, not hybrid/RRF)
RETRIEVAL_RELEVANCE_THRESHOLD=0.0

# Reranker (cross-encoder API — enabled when both URL and model are set)
RERANKER_BASE_URL=http://192.168.1.150:8083/v1
RERANKER_MODEL=qwen3-reranker-0.6b-q8_0.gguf
RERANKER_TOP_N=5

# Sub-agent (autonomous document analysis)
SUB_AGENT_ENABLED=true
SUB_AGENT_MAX_ITERATIONS=4
SUB_AGENT_MAX_CHUNKS_PER_READ=20

# Text-to-SQL (query your data via natural language)
# TEXT_TO_SQL_ENABLED=true
# TEXT_TO_SQL_MAX_ROWS=50
# TEXT_TO_SQL_TIMEOUT_SECONDS=5

# Web Search (fallback when documents don't have the answer)
# WEB_SEARCH_ENABLED=false
# WEB_SEARCH_PROVIDER=searxng          # searxng | tavily | brave
# WEB_SEARCH_URL=http://localhost:8888  # SearXNG instance URL
# WEB_SEARCH_API_KEY=                   # API key for Tavily/Brave
# WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=exa
