# Forge — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Application ────────────────────────────────────────────
APP_NAME=Forge
DEBUG=false

# ── Database ───────────────────────────────────────────────
# Path is relative to backend/ directory (where uvicorn runs)
DATABASE_URL=sqlite+aiosqlite:///./forge.db

# ── CORS ───────────────────────────────────────────────────
# JSON array of allowed origins. Add your domain and/or LAN IP:
# CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000","http://0.0.0.0:3000"]

# ── Authentication ────────────────────────────────────────
# Generate a secret key:
#   Linux/macOS: openssl rand -hex 32
#   Python:      python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin # change this to a strong password

# ── LLM Provider ─────────────────────────────────────────
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
