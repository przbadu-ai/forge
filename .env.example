# Forge — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Application ────────────────────────────────────────────
APP_NAME=Forge
DEBUG=false

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./forge.db

# ── CORS ───────────────────────────────────────────────────
# Comma-separated allowed origins. Add your LAN IP to access from other devices:
# CORS_ORIGINS=["http://localhost:3000","http://192.168.1.100:3000"]
CORS_ORIGINS=["http://localhost:3000","http://0.0.0.0:3000"]

# ── Authentication (Phase 2) ──────────────────────────────
# SECRET_KEY=change-me-to-a-random-256-bit-key

# ── LLM Provider (Phase 3) ────────────────────────────────
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
